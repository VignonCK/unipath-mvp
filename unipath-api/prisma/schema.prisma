// Ce fichier décrit la structure de toute la base de données
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

// Indique à Prisma de générer le client JavaScript pour interagir avec la base de données.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Définit la connexion à la base de données PostgreSQL, en utilisant l'URL stockée dans la variable d'environnement DATABASE_URL

model Candidat {
  id            String        @id @default(uuid()) // Identifiant unique (UUID généré automatiquement).
  matricule     String        @unique // matricule: Numéro unique généré par la base (trigger PostgreSQL)
  nom           String
  prenom        String
  anip          String?       @unique // Identifiant ANIP du candidat (12 chiffres, unique)
  serie         String? // Série du cursus scolaire (A, B, C, D, E, F, G)
  sexe          String? // Sexe du candidat (M/F)
  nationalite   String? // Nationalité du candidat
  email         String        @unique // nom, prenom, email: Informations personnelles, email doit être unique
  emailConfirme Boolean       @default(false) // Confirmation de l'email par le candidat
  telephone     String?
  dateNaiss     DateTime?
  lieuNaiss     String? // telephone, dateNaiss, lieuNaiss: Champs optionnels (le ?).
  role          Role          @default(CANDIDAT) // Rôle de l'utilisateur (par défaut CANDIDAT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt // createdAt, updatedAt: Dates de création et de mise à jour (gérées automatiquement)
  inscriptions  Inscription[] // inscriptions: Liste des inscriptions du candidat (relation 1-n).
  dossier       Dossier? // dossier: Dossier du candidat (relation 1-1, optionnelle).

  @@index([anip]) // Index pour optimiser les recherches par ANIP
}

model MembreCommission {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String?
  role      Role     @default(COMMISSION)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdministrateurDGES {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String?
  role      Role     @default(DGES)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Controleur {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String?
  role      Role     @default(CONTROLEUR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Concours {
  id                   String        @id @default(uuid())
  libelle              String
  etablissement        String? // Établissement organisateur du concours
  dateDebut            DateTime
  dateFin              DateTime
  dateComposition      DateTime? // Date de composition du concours
  description          String? // Champs principaux : nom, dates, description optionnelle.
  fraisParticipation   Int? // Frais de participation au concours (en FCFA)
  seriesAcceptees      String[]      @default([]) // Séries acceptées pour ce concours (ex: ["C", "D"])
  matieres             String[]      @default([]) // Matières évaluées lors du concours (ex: ["Mathématiques", "Physique"])
  piecesRequises       Json? // Configuration des pièces requises pour le dossier candidat
  dateDebutDepot       DateTime? // Date de début de dépôt des dossiers
  dateFinDepot         DateTime? // Date de fin de dépôt des dossiers
  dateDebutComposition DateTime? // Date de début de composition
  dateFinComposition   DateTime? // Date de fin de composition
  createdAt            DateTime      @default(now())
  inscriptions         Inscription[] // inscriptions: Liste des inscriptions à ce concours.

  @@index([dateDebutDepot])
  @@index([dateFinDepot])
}

model Inscription {
  id                 String              @id @default(uuid())
  numeroInscription  String?             @unique // Numéro d'inscription unique (ex: UAC-2026-MED-00123)
  candidatId         String
  concoursId         String
  note               Float? // Note obtenue au concours (null = absent)
  createdAt          DateTime            @default(now())
  candidat           Candidat            @relation(fields: [candidatId], references: [id])
  concours           Concours            @relation(fields: [concoursId], references: [id]) // Relations : chaque inscription appartient à un candidat et un concours.
  dossierInscription DossierInscription? // Relation 1-1 avec DossierInscription (dossier concours)

  @@unique([candidatId, concoursId]) // Contrainte : un candidat ne peut s'inscrire qu'une seule fois à un même concours.
  @@index([candidatId])
  @@index([concoursId])
}

model DossierInscription {
  id            String @id @default(uuid())
  inscriptionId String @unique // Relation 1-1 avec Inscription

  // Pièces spécifiques au concours
  quittanceUrl String? // URL de la quittance de paiement (obligatoire pour validation)
  piecesExtras Json? // Pièces personnalisées configurables par concours { "diplome": "url", "cv": "url" }

  // Statut et workflow
  statut StatutDossier @default(EN_ATTENTE) // État du dossier d'inscription

  // Décision de la commission
  commentaireRejet       String? // Commentaire de la commission en cas de rejet
  commentaireSousReserve String? // Commentaire de la commission en cas de validation sous réserve
  decisionCommissionPar  String? // ID du membre commission qui a pris la décision
  decisionCommissionDate DateTime? // Date de la décision de la commission

  // Décision du contrôleur
  decisionControleurPar  String? // ID du contrôleur qui a validé/modifié la décision
  decisionControleurDate DateTime? // Date de la décision du contrôleur
  commentaireControleur  String? // Commentaire du contrôleur (si modification de décision)

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inscription   Inscription     @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)
  actionHistory ActionHistory[] // Historique des actions sur ce dossier d'inscription

  @@index([inscriptionId])
  @@index([statut])
  @@index([createdAt])
}

model Dossier {
  id            String   @id @default(uuid())
  candidatId    String   @unique
  acteNaissance String?
  carteIdentite String?
  photo         String?
  releve        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  candidat      Candidat @relation(fields: [candidatId], references: [id]) // Un dossier est lié à un seul candidat (relation 1-1, candidatId unique).
}

enum StatutDossier {
  EN_ATTENTE
  VALIDE_PAR_COMMISSION // Commission a validé, attend contrôleur
  REJETE_PAR_COMMISSION // Commission a rejeté, attend contrôleur
  SOUS_RESERVE_PAR_COMMISSION // Commission a mis sous réserve, attend contrôleur
  VALIDE // Validé définitivement par contrôleur
  REJETE // Rejeté définitivement par contrôleur
  SOUS_RESERVE // Sous réserve définitif par contrôleur
}

enum Role {
  CANDIDAT
  COMMISSION
  CONTROLEUR
  DGES
}

model ActionHistory {
  id                   String             @id @default(uuid())
  utilisateurId        String // ID de l'utilisateur qui a effectué l'action
  dossierInscriptionId String // ID du dossier d'inscription concerné par l'action
  typeAction           String // Type d'action: DOSSIER_CREE, PIECE_AJOUTEE, PIECE_SUPPRIMEE, DOSSIER_VALIDE, DOSSIER_REJETE, DOSSIER_SOUMIS
  details              Json? // Détails optionnels de l'action au format JSON
  timestamp            DateTime           @default(now())
  ipAddress            String? // Adresse IP de l'utilisateur (pour audit)
  userAgent            String? // User Agent du navigateur (pour audit)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  dossierInscription   DossierInscription @relation(fields: [dossierInscriptionId], references: [id], onDelete: Cascade)

  @@index([dossierInscriptionId])
  @@index([utilisateurId])
  @@index([timestamp])
  @@index([typeAction])
  @@index([dossierInscriptionId, timestamp(sort: Desc)])
  @@index([utilisateurId, timestamp(sort: Desc)])
}

// ============================================
// Système de Notifications Intégré
// ============================================

model Notification {
  id        String           @id @default(uuid())
  userId    String // Candidat, Commission, ou DGES
  type      NotificationType
  title     String
  message   String           @db.Text
  data      Json? // Données additionnelles
  read      Boolean          @default(false)
  readAt    DateTime?
  priority  PriorityLevel    @default(NORMAL)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  expiresAt DateTime? // Auto-suppression après 2 ans

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, read])
  @@index([type])
  @@index([expiresAt])
}

enum NotificationType {
  PRE_INSCRIPTION
  VALIDATION
  CONVOCATION
  REJET
  NOUVEAU_DOSSIER
  RAPPORT_HEBDO
  RAPPORT_MENSUEL
  SYSTEME
  ALERTE
}

enum PriorityLevel {
  LOW
  NORMAL
  HIGH
  URGENT
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  name      String           @unique
  type      NotificationType
  subject   String
  htmlBody  String           @db.Text
  textBody  String?          @db.Text
  variables Json // Liste des variables disponibles
  isActive  Boolean          @default(true)
  isDefault Boolean          @default(false)
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type])
  @@index([isActive])
}

model EmailDelivery {
  id             String         @id @default(uuid())
  notificationId String?        // Peut être null pour emails legacy
  userId         String?        // Peut être null pour emails de confirmation (candidat pas encore créé)
  recipient      String
  subject        String
  status         DeliveryStatus @default(PENDING)
  messageId      String?        // ID du serveur SMTP
  attempts       Int            @default(0)
  lastAttemptAt  DateTime?      // Date de la dernière tentative réelle (traçabilité)
  nextRetryAt    DateTime?      // Date de la prochaine tentative programmée
  sentAt         DateTime?
  deliveredAt    DateTime?
  bouncedAt      DateTime?
  errorMessage   String?        @db.Text
  smtpCode       String?
  htmlBody       String?        @db.Text  // Contenu HTML de l'email
  textBody       String?        @db.Text  // Contenu texte de l'email
  attachments    Json?          // Array de { filename, path, contentType }
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([notificationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([status, nextRetryAt])  // Index pour la requête du worker
}

enum DeliveryStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  EXPIRED
}

model UserPreferences {
  id          String   @id @default(uuid())
  userId      String   @unique
  preferences Json // Structure: { [NotificationType]: { email: bool, inApp: bool } }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model NotificationAuditLog {
  id           String         @id @default(uuid())
  eventType    AuditEventType
  userId       String? // Utilisateur concerné
  actorId      String? // Utilisateur qui a effectué l'action
  resourceId   String? // ID de la ressource (notification, template, etc.)
  resourceType String? // Type de ressource
  details      Json? // Détails de l'événement
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime       @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([actorId])
  @@index([timestamp(sort: Desc)])
  @@index([resourceType, resourceId])
}

enum AuditEventType {
  NOTIFICATION_CREATED
  NOTIFICATION_SENT
  NOTIFICATION_DELIVERED
  NOTIFICATION_FAILED
  NOTIFICATION_READ
  NOTIFICATION_DELETED
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  TEMPLATE_DELETED
  PREFERENCES_UPDATED
  DATA_ACCESSED
  RETRY_ATTEMPTED
  ALERT_CREATED
}

model SystemAlert {
  id         String        @id @default(uuid())
  type       AlertType
  severity   AlertSeverity
  title      String
  message    String        @db.Text
  data       Json?
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([resolved])
  @@index([severity])
  @@index([createdAt(sort: Desc)])
}

enum AlertType {
  HIGH_FAILURE_RATE
  QUEUE_OVERLOAD
  SMTP_ERROR
  DELIVERY_ISSUE
  SYSTEM_ERROR
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}
