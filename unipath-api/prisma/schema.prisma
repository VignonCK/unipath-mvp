generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidat {
  id                    String                  @id @default(uuid())
  matricule             String                  @unique
  nom                   String
  prenom                String
  anip                  String?                 @unique
  serie                 String?
  sexe                  String?
  nationalite           String?
  email                 String                  @unique
  emailConfirme         Boolean                 @default(false)
  telephone             String?
  dateNaiss             DateTime?
  lieuNaiss             String?
  role                  Role                    @default(CANDIDAT)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  DiplomeLicence        DiplomeLicence?
  dossier               Dossier?
  inscriptions          Inscription[]
  InscriptionAcademique InscriptionAcademique[]

  @@index([anip])
}

model MembreCommission {
  id        String             @id @default(uuid())
  nom       String
  prenom    String
  email     String             @unique
  telephone String?
  role      Role               @default(COMMISSION)
  sousRole  SousRoleCommission // Sous-rôle: EXAMINATEUR ou CONTROLEUR
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([sousRole])
}

model AdministrateurDGES {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String?
  role      Role     @default(DGES)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Controleur {
  id        String   @id @default(uuid())
  nom       String
  prenom    String
  email     String   @unique
  telephone String?
  role      Role     @default(CONTROLEUR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Concours {
  id                   String        @id @default(uuid())
  libelle              String
  etablissement        String?
  dateDebut            DateTime
  dateFin              DateTime
  dateComposition      DateTime?
  description          String?
  fraisParticipation   Int?
  seriesAcceptees      String[]      @default([])
  matieres             String[]      @default([])
  piecesRequises       Json?
  dateDebutDepot       DateTime?
  dateFinDepot         DateTime?
  dateDebutComposition DateTime?
  dateFinComposition   DateTime?
  createdAt            DateTime      @default(now())
  inscriptions         Inscription[]

  @@index([dateDebutDepot])
  @@index([dateFinDepot])
}

model Inscription {
  id                     String              @id @default(uuid())
  numeroInscription      String?             @unique
  candidatId             String
  concoursId             String
  note                   Float?
  createdAt              DateTime            @default(now())
  candidat               Candidat            @relation(fields: [candidatId], references: [id])
  concours               Concours            @relation(fields: [concoursId], references: [id])
  dossierInscription     DossierInscription?

  @@unique([candidatId, concoursId])
  @@index([candidatId])
  @@index([concoursId])
}

model DossierInscription {
  id            String @id @default(uuid())
  inscriptionId String @unique

  // Pièces spécifiques au concours
  quittanceUrl String?
  piecesExtras Json?

  // Statut et workflow
  statut StatutDossier @default(EN_ATTENTE)

  // ✅ NOUVEAU : Verdict Examinateur 1
  verdict1Par          String?
  verdict1             Verdict?
  verdict1Motif        String?
  verdict1Date         DateTime?
  verdict1ModifieCount Int       @default(0)

  // ✅ NOUVEAU : Verdict Examinateur 2
  verdict2Par          String?
  verdict2             Verdict?
  verdict2Motif        String?
  verdict2Date         DateTime?
  verdict2ModifieCount Int       @default(0)

  // ✅ NOUVEAU : Décision Contrôleur (Double Verdict)
  decisionControleur      Verdict?
  decisionControleurMotif String?
  decisionControleurDate  DateTime?
  decisionControleurPar   String?

  // Anciens champs (conservés pour compatibilité)
  commentaireRejet       String?
  commentaireSousReserve String?
  decisionCommissionPar  String?
  decisionCommissionDate DateTime?
  commentaireControleur  String?

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inscription   Inscription     @relation(fields: [inscriptionId], references: [id], onDelete: Cascade)
  actionHistory ActionHistory[]

  @@index([inscriptionId])
  @@index([statut])
  @@index([verdict1Par])
  @@index([verdict2Par])
  @@index([decisionControleurPar])
  @@index([createdAt])
}

model Dossier {
  id            String   @id @default(uuid())
  candidatId    String   @unique
  acteNaissance String?
  carteIdentite String?
  photo         String?
  releve        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  candidat      Candidat @relation(fields: [candidatId], references: [id])
}

model ActionHistory {
  id                   String             @id @default(uuid())
  utilisateurId        String
  dossierInscriptionId String
  typeAction           String
  details              Json?
  timestamp            DateTime           @default(now())
  ipAddress            String?
  userAgent            String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  dossierInscription   DossierInscription @relation(fields: [dossierInscriptionId], references: [id], onDelete: Cascade)

  @@index([dossierInscriptionId])
  @@index([utilisateurId])
  @@index([timestamp])
  @@index([typeAction])
  @@index([dossierInscriptionId, timestamp(sort: Desc)])
  @@index([utilisateurId, timestamp(sort: Desc)])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  readAt    DateTime?
  priority  PriorityLevel    @default(NORMAL)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  expiresAt DateTime?

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, read])
  @@index([type])
  @@index([expiresAt])
}

model NotificationTemplate {
  id        String           @id @default(uuid())
  name      String           @unique
  type      NotificationType
  subject   String
  htmlBody  String
  textBody  String?
  variables Json
  isActive  Boolean          @default(true)
  isDefault Boolean          @default(false)
  createdBy String
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([type])
  @@index([isActive])
}

model EmailDelivery {
  id             String         @id @default(uuid())
  notificationId String?
  userId         String?
  recipient      String
  subject        String
  status         DeliveryStatus @default(PENDING)
  messageId      String?
  attempts       Int            @default(0)
  lastAttemptAt  DateTime?
  sentAt         DateTime?
  deliveredAt    DateTime?
  bouncedAt      DateTime?
  errorMessage   String?
  smtpCode       String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  htmlBody       String?
  textBody       String?
  attachments    Json?
  nextRetryAt    DateTime?

  @@index([notificationId])
  @@index([userId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([createdAt, status])
}

model UserPreferences {
  id          String   @id @default(uuid())
  userId      String   @unique
  preferences Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model NotificationAuditLog {
  id           String         @id @default(uuid())
  eventType    AuditEventType
  userId       String?
  actorId      String?
  resourceId   String?
  resourceType String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  timestamp    DateTime       @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([actorId])
  @@index([timestamp(sort: Desc)])
  @@index([resourceType, resourceId])
}

model SystemAlert {
  id         String        @id @default(uuid())
  type       AlertType
  severity   AlertSeverity
  title      String
  message    String
  data       Json?
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([resolved])
  @@index([severity])
  @@index([createdAt(sort: Desc)])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DiplomeLicence {
  id         String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  candidatId String   @unique
  filiereId  String
  mention    Mention
  annee      String
  verifie    Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
  Candidat   Candidat @relation(fields: [candidatId], references: [id])
  Filiere    Filiere  @relation(fields: [filiereId], references: [id])

  @@index([filiereId])
  @@index([verifie])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Etablissement {
  id                    String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  nom                   String
  type                  TypeEtablissement
  ville                 String
  code                  String                  @unique
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now())
  Filiere               Filiere[]
  InscriptionAcademique InscriptionAcademique[]

  @@index([code])
  @@index([type])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Filiere {
  id                    String                  @id @default(dbgenerated("(gen_random_uuid())::text"))
  nom                   String
  etablissementId       String
  dureeAnnees           Int
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @default(now())
  DiplomeLicence        DiplomeLicence[]
  Etablissement         Etablissement           @relation(fields: [etablissementId], references: [id])
  InscriptionAcademique InscriptionAcademique[]

  @@unique([etablissementId, nom])
  @@index([etablissementId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model InscriptionAcademique {
  id              String        @id @default(dbgenerated("(gen_random_uuid())::text"))
  candidatId      String
  etablissementId String
  filiereId       String
  niveau          NiveauEtude
  anneeAcademique String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @default(now())
  Candidat        Candidat      @relation(fields: [candidatId], references: [id])
  Etablissement   Etablissement @relation(fields: [etablissementId], references: [id])
  Filiere         Filiere       @relation(fields: [filiereId], references: [id])
  Resultat        Resultat?

  @@unique([candidatId, filiereId, niveau, anneeAcademique], map: "InscriptionAcademique_candidatId_filiereId_niveau_anneeAcademiq")
  @@index([anneeAcademique])
  @@index([candidatId])
  @@index([etablissementId])
  @@index([filiereId])
  @@index([niveau])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Resultat {
  id                      String                @id @default(dbgenerated("(gen_random_uuid())::text"))
  inscriptionAcademiqueId String                @unique
  moyenne                 Float
  mention                 Mention
  valide                  Boolean               @default(false)
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @default(now())
  InscriptionAcademique   InscriptionAcademique @relation(fields: [inscriptionAcademiqueId], references: [id])
}

enum StatutDossier {
  EN_ATTENTE
  VALIDE_PAR_COMMISSION
  REJETE_PAR_COMMISSION
  SOUS_RESERVE_PAR_COMMISSION
  VALIDE
  REJETE
  SOUS_RESERVE
}

enum Verdict {
  VALIDE
  REJETE
  SOUS_RESERVE
}

enum Role {
  CANDIDAT
  COMMISSION
  CONTROLEUR
  DGES
}

enum SousRoleCommission {
  EXAMINATEUR
  CONTROLEUR
}

enum NotificationType {
  PRE_INSCRIPTION
  VALIDATION
  CONVOCATION
  REJET
  NOUVEAU_DOSSIER
  RAPPORT_HEBDO
  RAPPORT_MENSUEL
  SYSTEME
  ALERTE
}

enum PriorityLevel {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum DeliveryStatus {
  PENDING
  QUEUED
  PROCESSING
  SENT
  DELIVERED
  FAILED
  BOUNCED
  EXPIRED
}

enum AuditEventType {
  NOTIFICATION_CREATED
  NOTIFICATION_SENT
  NOTIFICATION_DELIVERED
  NOTIFICATION_FAILED
  NOTIFICATION_READ
  NOTIFICATION_DELETED
  TEMPLATE_CREATED
  TEMPLATE_UPDATED
  TEMPLATE_DELETED
  PREFERENCES_UPDATED
  DATA_ACCESSED
  RETRY_ATTEMPTED
  ALERT_CREATED
}

enum AlertType {
  HIGH_FAILURE_RATE
  QUEUE_OVERLOAD
  SMTP_ERROR
  DELIVERY_ISSUE
  SYSTEM_ERROR
}

enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum Mention {
  PASSABLE
  ASSEZ_BIEN
  BIEN
  TRES_BIEN
  EXCELLENT
}

enum NiveauEtude {
  L1
  L2
  L3
  M1
  M2
}

enum TypeEtablissement {
  PUBLIC
  PRIVE
}
