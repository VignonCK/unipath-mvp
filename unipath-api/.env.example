DATABASE_URL="postgresql://user:password@host:5432/database"
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
PORT=3001
APP_URL=http://localhost:5173

# SMTP Configuration (Email System)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM_EMAIL=noreply@unipath.bj
SMTP_FROM_NAME=UniPath

# Legacy Email Configuration (deprecated - use SMTP_* instead)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com

# Application Configuration
ACADEMIC_YEAR=2024-2025

# Email Queue Configuration
EMAIL_QUEUE_ENABLED=true
EMAIL_RETRY_DELAYS=1,5,15,60,240
EMAIL_RATE_LIMIT_PER_USER=10
EMAIL_RATE_LIMIT_GLOBAL=100

# PHP Email Service
PHP_EMAIL_SERVICE_URL=http://localhost:3001/php/EmailService.php

# Redis Configuration (pour le système de notifications)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Notification System Configuration
NOTIFICATION_QUEUE_CONCURRENCY=10
NOTIFICATION_MAX_RETRIES=5
NOTIFICATION_RATE_LIMIT=100
WEBSOCKET_PORT=3001
WEBSOCKET_CORS_ORIGIN=http://localhost:5173
